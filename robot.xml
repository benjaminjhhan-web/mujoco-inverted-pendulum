<mujoco>
  <compiler coordinate="local" angle="radian"/>
  <option timestep="0.002"/> 
  <worldbody>
    <light name="top" pos="0 0 2"/>
    <geom name="floor" type="plane" size="1 1 0.1" rgba="0.5 0.5 0.5 1"/>
    <body name="cart" pos="0 0 0.1">
      <joint name="slide" type="slide" axis="1 0 0" range="-2 2"/>
      <geom type="box" size="0.1 0.1 0.1" rgba="0 1 0 1"/>
      <body name="pole" pos="0 0 0.2">
        <joint name="hinge" type="hinge" axis="0 1 0" pos="0 0 -0.2"/>
        <geom type="cylinder" size="0.02 0.2" mass="0.1" rgba="1 0 0 1"/>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor name="cart_motor" joint="slide" gear="100"/>
  </actuator>
</mujoco>